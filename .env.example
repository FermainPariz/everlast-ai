# ============================================================
# Everlast AI RAG System — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase — find these in: supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...          # Safe to expose (read-only under RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJ...              # NEVER expose to client — server-only

# OpenAI — for generating embeddings (text-embedding-3-small)
# Get at: platform.openai.com → API Keys
OPENAI_API_KEY=sk-...

# Anthropic — for generating answers (claude-haiku-4-5)
# Get at: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# App Config
NEXT_PUBLIC_DEFAULT_WORKSPACE=default
